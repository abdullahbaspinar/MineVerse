rules_version = '2';

// Firebase Console → Storage → Rules → yapıştır → Yayınla
//
// ÖNEMLİ: Ziyaretçilerin sitede kapak görsellerini görebilmesi için
// `allow read` bu klasörlerde herkese açık olmalı (if true).
// Sadece `request.auth != null` ile okuma yaparsanız, canlı sitede
// görseller 403/boş kalır; yüklemek adminde çalışsa bile liste sayfasında görünmez.

service firebase.storage {
  match /b/{bucket}/o {
    match /covers/{collection}/{fileName} {
      allow read: if true;
      allow create: if request.auth != null
        && (collection == 'posts' || collection == 'videos')
        && request.resource.size < 6 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null;
    }
  }
}
